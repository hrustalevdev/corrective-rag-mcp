{
  "name": "corrective-rag-mcp",
  "version": "1.0.0",
  "description": "MCP server for RAG knowledge base with Corrective RAG pipeline",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "npx -y @modelcontextprotocol/inspector tsx --env-file=.env src/index.ts",
    "test": "vitest",
    "test:index": "tsx --env-file=.env scripts/test-indexer.ts",
    "check": "biome check --write src",
    "lint": "biome lint src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/ollama": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chromadb": "^3.4.3",
    "minisearch": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  },
  "private": true
}
